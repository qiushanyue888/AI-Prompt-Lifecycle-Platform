.container {
  padding: 20px;
}

.title {
  font-size: 22px;
  font-weight: bold;
  text-align: center;
  margin-bottom: 20px;
}

.form {
  background-color: #f8f8f8;
  padding: 15px;
  border-radius: 8px;
  margin-bottom: 20px;
}

.form-label {
  font-size: 15px;
  font-weight: bold;
  margin-bottom: 5px;
  margin-top: 10px;
}

.form-textarea {
  width: 100%;
  border: 1px solid #ddd;
  padding: 10px;
  border-radius: 4px;
  height: 80px;
  box-sizing: border-box;
  margin-bottom: 10px;
}

button {
  width: 100%;
  margin-top: 15px;
}

.result {
  background-color: #e6f7ff;
  padding: 20px;
  border-radius: 8px;
  text-align: center;
}

.result-title {
  font-size: 16px;
  color: #666;
  margin-bottom: 10px;
}

.result-score {
  font-size: 48px;
  font-weight: bold;
  color: #1890ff;
  margin-bottom: 10px;
}

.result-desc {
  font-size: 15px;
  color: #333;
}